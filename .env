# Kredensial API Bitget (JANGAN commit file .env asli ke git!)
BITGET_API_KEY=isi_api_key_kamu
BITGET_API_SECRET=isi_api_secret_kamu
BITGET_API_PASSWORD=isi_passphrase_kamu

# Pengaturan strategi
TIMEFRAME=1h
LIMIT=100
USDT_AMOUNT=50
LEVERAGE=5
TRAILING_PERCENT=1.0
TP_PERCENT=2.0
THRESHOLD_MIN=70
WIN_PROB_MIN=80
INTERVAL_MINUTES=15

# Risk management (TripWire)
MAX_HOLD_MINUTES=240
DAILY_LOSS_LIMIT_USDT=-20

# WAJIB true dulu sampai kamu yakin bot berjalan benar di paper/testnet.
# Ganti ke false hanya kalau sudah siap live trading dengan uang sungguhan.
DRY_RUN=true
